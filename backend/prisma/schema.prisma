// School Management Portal — data model (Phase 1 core).
//
// Deployment model: ONE database per school (full instance per school), so there
// is no cross-tenant scoping here — every row already belongs to this school.
// `SchoolSettings` is a single-row table holding this deployment's white-label config.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── White-label config for this deployment ────────────────────────────────
model SchoolSettings {
  id            Int      @id @default(1) // single row, always id=1
  name          String
  shortName     String?
  primaryColor  String   @default("#1d4ed8")
  logoUrl       String?
  contactEmail  String?
  contactPhone  String?
  currency      String   @default("INR")
  timezone      String   @default("Asia/Kolkata")
  academicYear  String?  // e.g. "2026-2027"

  // Geofence for staff on-campus check-in (set by Admin in School Setup)
  latitude       Float?
  longitude      Float?
  geofenceRadius Int          @default(150) // metres

  // Academic session — single source of truth for working days,
  // attendance % and student onboarding/retention.
  sessionStart   DateTime?
  sessionEnd     DateTime?
  saturdayRule   SaturdayRule @default(NONE)

  updatedAt     DateTime @updatedAt
}

// How Saturdays are treated for working-day counts.
enum SaturdayRule {
  NONE      // all Saturdays are working days
  ALL       // every Saturday is a holiday
  ALTERNATE // 2nd & 4th Saturday of each month are holidays
}

// ── Auth ──────────────────────────────────────────────────────────────────
enum Role {
  SUPER_ADMIN
  ADMIN
  DEAN
  ACCOUNTANT
  TEACHER
  STUDENT
  PARENT
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  phone              String?  @unique
  passwordHash       String
  role               Role
  isActive           Boolean  @default(true)
  mustChangePassword Boolean  @default(true)
  casualQuota        Int      @default(12) // annual leave days, by category
  sickQuota          Int      @default(8)
  lastLoginAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  teacher           Teacher?
  student           Student?       @relation("StudentLogin")
  children          Student[]      @relation("ParentChildren")
  notices           Notice[]
  homework          Homework[]
  expensesSubmitted Expense[]      @relation("ExpenseSubmitter")
  expensesDecided   Expense[]      @relation("ExpenseDecider")
  leaveRequests     LeaveRequest[] @relation("LeaveApplicant")
  leaveDecisions    LeaveRequest[] @relation("LeaveApprover")
  notifications     Notification[]
  uploadedNotes     Note[]
  staffAttendance   StaffAttendance[]
  ratingsGiven      TeacherRating[]
  feedbackAuthored  StudentFeedback[] @relation("FeedbackAuthor")
  refreshTokens     RefreshToken[]

  @@index([role])
}

// ── Refresh tokens (rotating; enables short-lived access tokens + revocation) ─
model RefreshToken {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String    @unique // sha256 of the raw token (raw lives only in the cookie)
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ── Academic structure ─────────────────────────────────────────────────────
model Class {
  id            String         @id @default(cuid())
  name          String // e.g. "Grade 5", "X"
  order         Int            @default(0) // for sorting / promotion
  sections      Section[]
  feeStructures FeeStructure[]
  exams         Exam[]
  createdAt     DateTime       @default(now())

  @@unique([name])
}

model Section {
  id           String    @id @default(cuid())
  name         String    // e.g. "A", "B"
  class        Class     @relation(fields: [classId], references: [id])
  classId      String
  classTeacher Teacher?  @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  classTeacherId String?
  students     Student[]
  notices      Notice[]
  homework     Homework[]
  notes        Note[]
  teachingAssignments TeachingAssignment[]
  createdAt    DateTime  @default(now())

  @@unique([classId, name])
}

// ── People ──────────────────────────────────────────────────────────────────
enum StaffType {
  TEACHING
  NON_TEACHING
}

model Teacher {
  id             String    @id @default(cuid())
  user           User?     @relation(fields: [userId], references: [id])
  userId         String?   @unique
  employeeNo     String    @unique
  firstName      String
  lastName       String
  staffType      StaffType @default(TEACHING)
  qualifications String?
  joiningDate    DateTime?
  phone          String?
  email          String?
  photoFile       String?          // filename in uploads/<tenant>/photos (served via /api/teachers/:id/photo)
  isActive        Boolean          @default(true)
  classTeacherOf  Section[]        @relation("ClassTeacher")
  salaryStructure SalaryStructure?
  payslips        Payslip[]
  settlements     Settlement[]
  teachingAssignments TeachingAssignment[]
  ratingsReceived TeacherRating[]
  complaintsAbout Complaint[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

enum EnrollmentStatus {
  ACTIVE
  INACTIVE
  ALUMNI
  TRANSFERRED
}

model Student {
  id            String           @id @default(cuid())
  user          User?            @relation("StudentLogin", fields: [userId], references: [id])
  userId        String?          @unique
  parent        User?            @relation("ParentChildren", fields: [parentId], references: [id])
  parentId      String?
  admissionNo   String           @unique
  firstName     String
  lastName      String
  dateOfBirth   DateTime?
  gender        String?
  section       Section?         @relation(fields: [sectionId], references: [id])
  sectionId     String?
  guardianName  String?
  guardianPhone String?
  address       String?
  photoFile     String?            // filename in uploads/<tenant>/photos (served via /api/students/:id/photo)
  status        EnrollmentStatus   @default(ACTIVE)
  admissionDate DateTime?          // when they actually joined (onboarding)
  leftAt        DateTime?          // set when the student leaves (retention)
  attendance    AttendanceRecord[]
  invoices      Invoice[]
  marks         Mark[]
  feedback      StudentFeedback[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([sectionId])
  @@index([status])
}

// ── Attendance ──────────────────────────────────────────────────────────────
enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

model AttendanceRecord {
  id         String           @id @default(cuid())
  student    Student          @relation(fields: [studentId], references: [id])
  studentId  String
  sectionId  String // denormalised so a section's day can be queried directly
  date       DateTime // normalised to UTC midnight (day granularity)
  status     AttendanceStatus @default(PRESENT)
  note       String?
  markedById String? // user who recorded it
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([studentId, date])
  @@index([sectionId, date])
}

// ── Academic calendar holidays ────────────────────────────────────────────
// Explicitly-marked holidays (a date the Admin/Dean toggled off). Sundays and
// Saturdays-by-rule are computed, not stored. `note` (if set) is shown on the
// notice board the day before, then auto-disappears.
model Holiday {
  id        String   @id @default(cuid())
  date      DateTime @unique // normalised to UTC midnight
  note      String?
  createdAt DateTime @default(now())

  @@index([date])
}

// ── Staff on-campus attendance (geofenced self check-in) ──────────────────
model StaffAttendance {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  date      DateTime // normalised to UTC midnight (one check-in per day)
  checkInAt DateTime @default(now())
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([date])
}

// ── Notices / announcements ───────────────────────────────────────────────────
enum NoticeAudience {
  ALL // everyone
  STUDENTS // students (and parents)
  STAFF // teachers + accountants + admins
  SECTION // a specific class-section
}

model Notice {
  id        String         @id @default(cuid())
  title     String
  body      String
  audience  NoticeAudience @default(ALL)
  section   Section?       @relation(fields: [sectionId], references: [id])
  sectionId String? // required when audience = SECTION
  pinned    Boolean        @default(false)
  author    User?          @relation(fields: [authorId], references: [id])
  authorId  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([audience])
  @@index([sectionId])
}

// ── Fees ──────────────────────────────────────────────────────────────────────
// All amounts are whole rupees (INR), stored as Int.

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  UPI
  CARD
  CHEQUE
  ONLINE
  OTHER
}

// A reusable fee head for a class, e.g. "Tuition - Term 1".
model FeeStructure {
  id        String   @id @default(cuid())
  class     Class    @relation(fields: [classId], references: [id])
  classId   String
  name      String
  amount    Int
  createdAt DateTime @default(now())

  @@index([classId])
}

model Invoice {
  id         String        @id @default(cuid())
  student    Student       @relation(fields: [studentId], references: [id])
  studentId  String
  title      String // e.g. "Term 1 Fees 2026-27"
  total      Int
  amountPaid Int           @default(0)
  status     InvoiceStatus @default(PENDING)
  dueDate    DateTime?
  items      InvoiceItem[]
  payments   Payment[]
  paymentOrders PaymentOrder[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([studentId])
  @@index([status])
}

// A Razorpay online-payment attempt for an invoice. Links the gateway order to
// the invoice and gives us idempotent settlement (verify + webhook can't
// double-credit). Amounts are whole INR.
model PaymentOrder {
  id                String             @id // Razorpay order id (order_...)
  invoice           Invoice            @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId         String
  feeAmount         Int // invoice portion credited on success
  surcharge         Int // convenience fee paid by the parent
  grossAmount       Int // total charged (feeAmount + surcharge)
  status            PaymentOrderStatus @default(CREATED)
  razorpayPaymentId String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([invoiceId])
}

enum PaymentOrderStatus {
  CREATED
  PAID
  FAILED
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String
  name      String
  amount    Int
}

model Payment {
  id           String        @id @default(cuid())
  invoice      Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId    String
  amount       Int
  method       PaymentMethod @default(CASH)
  reference    String? // cheque no, txn id, note
  paidAt       DateTime      @default(now())
  recordedById String?
  createdAt    DateTime      @default(now())

  @@index([invoiceId])
}

// ── Schoolwork ────────────────────────────────────────────────────────────────
model Subject {
  id         String      @id @default(cuid())
  name       String      @unique
  code       String?     @unique
  homework   Homework[]
  examPapers ExamPaper[]
  notes      Note[]
  teachingAssignments TeachingAssignment[]
  createdAt  DateTime    @default(now())
}

// ── Teaching assignments (which teacher teaches which subject in a section) ──
model TeachingAssignment {
  id        String   @id @default(cuid())
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId String
  createdAt DateTime @default(now())

  @@unique([sectionId, subjectId]) // one teacher per subject per section
  @@index([teacherId])
  @@index([sectionId])
}

// ── Teacher ratings (students & parents rate their teachers; anonymous) ──────
model TeacherRating {
  id        String   @id @default(cuid())
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId String
  rater     User     @relation(fields: [raterId], references: [id], onDelete: Cascade)
  raterId   String
  raterRole Role
  stars     Int // 1–5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([raterId, teacherId]) // one rating per person per teacher (editable)
  @@index([teacherId])
}

// ── Teacher → student feedback & commendations ───────────────────────────────
enum StudentFeedbackType {
  FEEDBACK     // general feedback, student-facing (parents see it too)
  COMMENDATION // a positive highlight, surfaced to parents
}

model StudentFeedback {
  id        String              @id @default(cuid())
  student   Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  author    User?               @relation("FeedbackAuthor", fields: [authorId], references: [id])
  authorId  String?
  type      StudentFeedbackType @default(FEEDBACK)
  category  String // Academics / Behaviour / Sports / Discipline / Other
  message   String
  createdAt DateTime            @default(now())

  @@index([studentId])
}

// ── Complaints about staff (Dean + Super-Admin only; anonymity supported) ────
enum ComplaintStatus {
  OPEN
  RESOLVED
}

model Complaint {
  id             String          @id @default(cuid())
  aboutStaff     Teacher         @relation(fields: [aboutStaffId], references: [id], onDelete: Cascade)
  aboutStaffId   String
  // Identity is only stored for NON-anonymous complaints; null when anonymous.
  filedById      String?
  filedByLabel   String? // e.g. "Parent" / "Teacher" — null when anonymous
  anonymous      Boolean         @default(false)
  category       String // Behaviour / Teaching quality / Misconduct / Other
  message        String
  status         ComplaintStatus @default(OPEN)
  resolutionNote String?
  resolvedById   String?
  resolvedAt     DateTime?
  createdAt      DateTime        @default(now())

  @@index([aboutStaffId])
  @@index([status])
}

model Homework {
  id           String    @id @default(cuid())
  title        String
  description  String
  section      Section   @relation(fields: [sectionId], references: [id])
  sectionId    String
  subject      Subject?  @relation(fields: [subjectId], references: [id])
  subjectId    String?
  dueDate      DateTime?
  assignedBy   User?     @relation(fields: [assignedById], references: [id])
  assignedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([sectionId])
  @@index([subjectId])
}

// ── Payroll ─────────────────────────────────────────────────────────────────
// Monthly amounts in whole rupees (INR). India statutory deductions: PF and ESI
// are derived at run time; Professional Tax and TDS are configured per staff.

model SalaryStructure {
  id               String   @id @default(cuid())
  teacher          Teacher  @relation(fields: [teacherId], references: [id])
  teacherId        String   @unique
  basic            Int
  hra              Int      @default(0)
  da               Int      @default(0)
  conveyance       Int      @default(0)
  specialAllowance Int      @default(0)
  pfApplicable     Boolean  @default(true)
  esiApplicable    Boolean  @default(false)
  professionalTax  Int      @default(0) // state-wise monthly amount
  tdsMonthly       Int      @default(0) // monthly TDS deduction
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum PayslipStatus {
  GENERATED
  PAID
}

model Payslip {
  id               String        @id @default(cuid())
  teacher          Teacher       @relation(fields: [teacherId], references: [id])
  teacherId        String
  month            String // "YYYY-MM"
  // Earnings snapshot
  basic            Int
  hra              Int
  da               Int
  conveyance       Int
  specialAllowance Int
  gross            Int
  // Deductions snapshot
  pf               Int
  esi              Int
  professionalTax  Int
  tds              Int
  totalDeductions  Int
  net              Int
  status           PayslipStatus @default(GENERATED)
  paidAt           DateTime?
  createdAt        DateTime      @default(now())

  @@unique([teacherId, month])
  @@index([month])
}

// ── Full & Final settlement (staff exit dues) ────────────────────────────────
enum SettlementStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model Settlement {
  id             String           @id @default(cuid())
  teacher        Teacher          @relation(fields: [teacherId], references: [id])
  teacherId      String
  lastWorkingDay DateTime?
  pendingSalary  Int              // snapshot of unpaid payslips at creation
  bonus          Int              @default(0) // gratuity / one-off
  deductions     Int              @default(0) // advances, recoveries, notice shortfall
  netPayable     Int
  notes          String?
  status         SettlementStatus @default(PENDING)
  createdById    String?
  decidedById    String?
  decisionNote   String?
  decidedAt      DateTime?
  paidAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([teacherId])
  @@index([status])
}

// ── Expenses & approvals ──────────────────────────────────────────────────────
enum ExpenseStatus {
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

model Expense {
  id            String        @id @default(cuid())
  category      String
  description   String
  amount        Int // INR
  expenseDate   DateTime?
  status        ExpenseStatus @default(SUBMITTED)
  submittedBy   User?         @relation("ExpenseSubmitter", fields: [submittedById], references: [id])
  submittedById String?
  decidedBy     User?         @relation("ExpenseDecider", fields: [decidedById], references: [id])
  decidedById   String?
  decisionNote  String?
  decidedAt     DateTime?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([submittedById])
}

// ── Leave (hierarchical approvals) ────────────────────────────────────────────
enum LeaveKind {
  ADVANCE // permission for a future day off
  JUSTIFICATION // reason for a past unannounced absence
}

enum LeaveCategory {
  CASUAL
  SICK
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model LeaveRequest {
  id           String      @id @default(cuid())
  applicant    User          @relation("LeaveApplicant", fields: [applicantId], references: [id])
  applicantId  String
  kind         LeaveKind
  category     LeaveCategory @default(CASUAL)
  fromDate     DateTime
  toDate       DateTime
  reason       String
  status       LeaveStatus @default(PENDING)
  approver     User?       @relation("LeaveApprover", fields: [approverId], references: [id])
  approverId   String?
  decisionNote String?
  decidedAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([applicantId])
  @@index([status])
}

// ── In-app notifications ──────────────────────────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

// ── Exams, marks & report cards ───────────────────────────────────────────────
enum ExamStatus {
  DRAFT // marks being entered; not visible to students
  PUBLISHED // report cards visible to students/parents
}

model Exam {
  id        String      @id @default(cuid())
  name      String // e.g. "Term 1 Examination"
  class     Class       @relation(fields: [classId], references: [id])
  classId   String
  term      String? // e.g. "Term 1"
  examDate  DateTime?
  startDate DateTime? // exam period start (subject dates fall within this range)
  endDate   DateTime?
  status    ExamStatus  @default(DRAFT)
  papers    ExamPaper[]
  marks     Mark[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([classId])
}

model ExamPaper {
  id        String  @id @default(cuid())
  exam      Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  examId    String
  subject   Subject @relation(fields: [subjectId], references: [id])
  subjectId String
  maxMarks  Int
  passMarks Int       @default(33)
  date      DateTime? // exam date for this subject (datesheet)
  marks     Mark[]

  @@unique([examId, subjectId])
}

model Mark {
  id            String    @id @default(cuid())
  exam          Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  examId        String
  paper         ExamPaper @relation(fields: [paperId], references: [id], onDelete: Cascade)
  paperId       String
  student       Student   @relation(fields: [studentId], references: [id])
  studentId     String
  marksObtained Int
  updatedAt     DateTime  @updatedAt

  @@unique([paperId, studentId])
  @@index([examId, studentId])
}

// ── Notes sharing (file uploads) ──────────────────────────────────────────────
enum NoteStatus {
  PENDING // student upload awaiting moderation
  APPROVED
  REJECTED
}

model Note {
  id           String     @id @default(cuid())
  title        String
  description  String?
  subject      Subject?   @relation(fields: [subjectId], references: [id])
  subjectId    String?
  section      Section?   @relation(fields: [sectionId], references: [id])
  sectionId    String? // null = shared school-wide
  uploadedBy   User?      @relation(fields: [uploadedById], references: [id])
  uploadedById String?
  fileName     String // stored filename on disk
  originalName String
  mimeType     String
  size         Int
  status       NoteStatus @default(PENDING)
  createdAt    DateTime   @default(now())

  @@index([sectionId, status])
}

// ── Audit log (append-only: who did what, when) ──────────────────────────────
// Actor identity is snapshotted (email/role) so entries stay meaningful even if
// the user is later removed. No relation/cascade — the log must never be mutated.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String?
  actorRole  Role?
  action     String // e.g. "auth.login", "expense.approve", "marks.update"
  entityType String?
  entityId   String?
  summary    String // human-readable line
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
  @@index([entityType, entityId])
}
