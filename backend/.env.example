# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://school:school@localhost:5432/school_management?schema=public

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ── White-label / per-school instance config ──────────────
# These seed the SchoolSettings row for this deployment.
SCHOOL_NAME=Demo Public School
SCHOOL_SHORT_NAME=DPS
SCHOOL_PRIMARY_COLOR="#1d4ed8"
SCHOOL_LOGO_URL=
SCHOOL_CONTACT_EMAIL=admin@demoschool.in
SCHOOL_CONTACT_PHONE=+91-0000000000
SCHOOL_CURRENCY=INR
SCHOOL_TIMEZONE=Asia/Kolkata

# ── Seed admin (first login) ──────────────────────────────
SEED_ADMIN_EMAIL=admin@demoschool.in
SEED_ADMIN_PASSWORD=ChangeMe!123

# ── Online fee payment (Razorpay) ─────────────────────────
# Optional. Each school uses its OWN Razorpay account (money settles to their
# bank). Online pay turns on automatically once KEY_ID + KEY_SECRET are set.
# Use rzp_test_* keys to trial end-to-end, then swap in rzp_live_* keys.
# WEBHOOK_SECRET: set the same value in Razorpay Dashboard → Webhooks for
#   <your-domain>/api/fees/online/webhook (events: payment.captured, order.paid).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Convenience fee the parent pays on top so the school nets the full fee
# (2.36% ≈ Razorpay 2% + 18% GST).
CONVENIENCE_FEE_PERCENT=2.36
