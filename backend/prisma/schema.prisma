// School Management Portal — data model (Phase 1 core).
//
// Deployment model: ONE database per school (full instance per school), so there
// is no cross-tenant scoping here — every row already belongs to this school.
// `SchoolSettings` is a single-row table holding this deployment's white-label config.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── White-label config for this deployment ────────────────────────────────
model SchoolSettings {
  id            Int      @id @default(1) // single row, always id=1
  name          String
  shortName     String?
  primaryColor  String   @default("#1d4ed8")
  logoUrl       String?
  contactEmail  String?
  contactPhone  String?
  currency      String   @default("INR")
  timezone      String   @default("Asia/Kolkata")
  academicYear  String?  // e.g. "2026-2027"
  updatedAt     DateTime @updatedAt
}

// ── Auth ──────────────────────────────────────────────────────────────────
enum Role {
  SUPER_ADMIN
  ADMIN
  ACCOUNTANT
  TEACHER
  STUDENT
  PARENT
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  phone              String?  @unique
  passwordHash       String
  role               Role
  isActive           Boolean  @default(true)
  mustChangePassword Boolean  @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  teacher  Teacher?
  student  Student?
  notices  Notice[]
  homework Homework[]

  @@index([role])
}

// ── Academic structure ─────────────────────────────────────────────────────
model Class {
  id            String         @id @default(cuid())
  name          String // e.g. "Grade 5", "X"
  order         Int            @default(0) // for sorting / promotion
  sections      Section[]
  feeStructures FeeStructure[]
  createdAt     DateTime       @default(now())

  @@unique([name])
}

model Section {
  id           String    @id @default(cuid())
  name         String    // e.g. "A", "B"
  class        Class     @relation(fields: [classId], references: [id])
  classId      String
  classTeacher Teacher?  @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  classTeacherId String?
  students     Student[]
  notices      Notice[]
  homework     Homework[]
  createdAt    DateTime  @default(now())

  @@unique([classId, name])
}

// ── People ──────────────────────────────────────────────────────────────────
enum StaffType {
  TEACHING
  NON_TEACHING
}

model Teacher {
  id             String    @id @default(cuid())
  user           User?     @relation(fields: [userId], references: [id])
  userId         String?   @unique
  employeeNo     String    @unique
  firstName      String
  lastName       String
  staffType      StaffType @default(TEACHING)
  qualifications String?
  joiningDate    DateTime?
  phone          String?
  email          String?
  isActive        Boolean          @default(true)
  classTeacherOf  Section[]        @relation("ClassTeacher")
  salaryStructure SalaryStructure?
  payslips        Payslip[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

enum EnrollmentStatus {
  ACTIVE
  INACTIVE
  ALUMNI
  TRANSFERRED
}

model Student {
  id            String           @id @default(cuid())
  user          User?            @relation(fields: [userId], references: [id])
  userId        String?          @unique
  admissionNo   String           @unique
  firstName     String
  lastName      String
  dateOfBirth   DateTime?
  gender        String?
  section       Section?         @relation(fields: [sectionId], references: [id])
  sectionId     String?
  guardianName  String?
  guardianPhone String?
  address       String?
  status        EnrollmentStatus   @default(ACTIVE)
  attendance    AttendanceRecord[]
  invoices      Invoice[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([sectionId])
  @@index([status])
}

// ── Attendance ──────────────────────────────────────────────────────────────
enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

model AttendanceRecord {
  id         String           @id @default(cuid())
  student    Student          @relation(fields: [studentId], references: [id])
  studentId  String
  sectionId  String // denormalised so a section's day can be queried directly
  date       DateTime // normalised to UTC midnight (day granularity)
  status     AttendanceStatus @default(PRESENT)
  note       String?
  markedById String? // user who recorded it
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([studentId, date])
  @@index([sectionId, date])
}

// ── Notices / announcements ───────────────────────────────────────────────────
enum NoticeAudience {
  ALL // everyone
  STUDENTS // students (and parents)
  STAFF // teachers + accountants + admins
  SECTION // a specific class-section
}

model Notice {
  id        String         @id @default(cuid())
  title     String
  body      String
  audience  NoticeAudience @default(ALL)
  section   Section?       @relation(fields: [sectionId], references: [id])
  sectionId String? // required when audience = SECTION
  pinned    Boolean        @default(false)
  author    User?          @relation(fields: [authorId], references: [id])
  authorId  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([audience])
  @@index([sectionId])
}

// ── Fees ──────────────────────────────────────────────────────────────────────
// All amounts are whole rupees (INR), stored as Int.

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  UPI
  CARD
  CHEQUE
  ONLINE
  OTHER
}

// A reusable fee head for a class, e.g. "Tuition - Term 1".
model FeeStructure {
  id        String   @id @default(cuid())
  class     Class    @relation(fields: [classId], references: [id])
  classId   String
  name      String
  amount    Int
  createdAt DateTime @default(now())

  @@index([classId])
}

model Invoice {
  id         String        @id @default(cuid())
  student    Student       @relation(fields: [studentId], references: [id])
  studentId  String
  title      String // e.g. "Term 1 Fees 2026-27"
  total      Int
  amountPaid Int           @default(0)
  status     InvoiceStatus @default(PENDING)
  dueDate    DateTime?
  items      InvoiceItem[]
  payments   Payment[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([studentId])
  @@index([status])
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String
  name      String
  amount    Int
}

model Payment {
  id           String        @id @default(cuid())
  invoice      Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId    String
  amount       Int
  method       PaymentMethod @default(CASH)
  reference    String? // cheque no, txn id, note
  paidAt       DateTime      @default(now())
  recordedById String?
  createdAt    DateTime      @default(now())

  @@index([invoiceId])
}

// ── Schoolwork ────────────────────────────────────────────────────────────────
model Subject {
  id        String     @id @default(cuid())
  name      String     @unique
  code      String?    @unique
  homework  Homework[]
  createdAt DateTime   @default(now())
}

model Homework {
  id           String    @id @default(cuid())
  title        String
  description  String
  section      Section   @relation(fields: [sectionId], references: [id])
  sectionId    String
  subject      Subject?  @relation(fields: [subjectId], references: [id])
  subjectId    String?
  dueDate      DateTime?
  assignedBy   User?     @relation(fields: [assignedById], references: [id])
  assignedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([sectionId])
  @@index([subjectId])
}

// ── Payroll ─────────────────────────────────────────────────────────────────
// Monthly amounts in whole rupees (INR). India statutory deductions: PF and ESI
// are derived at run time; Professional Tax and TDS are configured per staff.

model SalaryStructure {
  id               String   @id @default(cuid())
  teacher          Teacher  @relation(fields: [teacherId], references: [id])
  teacherId        String   @unique
  basic            Int
  hra              Int      @default(0)
  da               Int      @default(0)
  conveyance       Int      @default(0)
  specialAllowance Int      @default(0)
  pfApplicable     Boolean  @default(true)
  esiApplicable    Boolean  @default(false)
  professionalTax  Int      @default(0) // state-wise monthly amount
  tdsMonthly       Int      @default(0) // monthly TDS deduction
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum PayslipStatus {
  GENERATED
  PAID
}

model Payslip {
  id               String        @id @default(cuid())
  teacher          Teacher       @relation(fields: [teacherId], references: [id])
  teacherId        String
  month            String // "YYYY-MM"
  // Earnings snapshot
  basic            Int
  hra              Int
  da               Int
  conveyance       Int
  specialAllowance Int
  gross            Int
  // Deductions snapshot
  pf               Int
  esi              Int
  professionalTax  Int
  tds              Int
  totalDeductions  Int
  net              Int
  status           PayslipStatus @default(GENERATED)
  paidAt           DateTime?
  createdAt        DateTime      @default(now())

  @@unique([teacherId, month])
  @@index([month])
}
