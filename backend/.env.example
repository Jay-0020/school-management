# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://school:school@localhost:5432/school_management?schema=public

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ── White-label / per-school instance config ──────────────
# These seed the SchoolSettings row for this deployment.
SCHOOL_NAME=Demo Public School
SCHOOL_SHORT_NAME=DPS
SCHOOL_PRIMARY_COLOR=#1d4ed8
SCHOOL_LOGO_URL=
SCHOOL_CONTACT_EMAIL=admin@demoschool.in
SCHOOL_CONTACT_PHONE=+91-0000000000
SCHOOL_CURRENCY=INR
SCHOOL_TIMEZONE=Asia/Kolkata

# ── Seed admin (first login) ──────────────────────────────
SEED_ADMIN_EMAIL=admin@demoschool.in
SEED_ADMIN_PASSWORD=ChangeMe!123
